@model EarlyYearsFoundationRecovery.Web.Models.LearningLogNoteFormViewModel

<div class="govuk-grid-row govuk-!-margin-top-4">
    <div class="govuk-grid-column-three-quarters">
        <div class="learning-log-prompt">
            <h2 class="govuk-heading-m">Add to your learning log</h2>

            <p class="govuk-body">
                Use this space to make notes on the reflection point. Do not enter any personal or sensitive information like children's names.
            </p>
            <p class="govuk-body">
                All your notes will be added to your personal
                <a class="govuk-link" href="/my-account/learning-log#@Model.LearningLogAnchor">learning log</a>.
            </p>

            <form method="post" action="/my-account/learning-log">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Title" />
                <input type="hidden" asp-for="TrainingModule" />
                <input type="hidden" asp-for="Name" />
                <input type="hidden" asp-for="NextPageName" />
                <input type="hidden" asp-for="NextPageModule" />
                <input type="hidden" asp-for="NextPageUrl" />
                <input type="hidden" asp-for="PageType" />

                <div class="govuk-form-group govuk-!-margin-bottom-4">
                    <label class="govuk-label" asp-for="Body">Your notes</label>
                    <textarea class="govuk-textarea" asp-for="Body" rows="5"></textarea>
                </div>

                <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible govuk-!-margin-top-4" />

                <div class="govuk-button-group">
                    @if (Model.PreviousPageUrl is not null)
                    {
                        <a class="govuk-button govuk-button--secondary" id="previous-action" href="@Model.PreviousPageUrl">@Model.PreviousPageLabel</a>
                    }
                    <govuk-button type="submit">@Model.SubmitLabel</govuk-button>
                </div>
            </form>
        </div>
    </div>
</div>
