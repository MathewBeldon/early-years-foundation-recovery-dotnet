@model EarlyYearsFoundationRecovery.Web.Models.Registration.WhereYouLiveViewModel
@{
    ViewData["Title"] = "Where you live";
}

@if (ViewData["BackLink"] is string backLink)
{
    <a class="govuk-back-link" href="@backLink">Back</a>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form asp-action="WhereYouLive" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <govuk-error-summary>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <govuk-error-summary-item>@error.ErrorMessage</govuk-error-summary-item>
                    }
                </govuk-error-summary>
            }

            <h1 class="govuk-heading-l">Where do you live?</h1>
            <p class="govuk-body">
                The training is based on the Early Years Foundation (EYFS) framework used in England.
                You can still use the training even if you live outside England.
            </p>

            <govuk-radios for="CountryId">
                <govuk-radios-fieldset legend="Where you live">
                    @foreach (var option in Model.Options)
                    {
                        <govuk-radios-item value="@option.Id">
                            <govuk-radios-item-label>@option.Label</govuk-radios-item-label>
                        </govuk-radios-item>
                    }
                </govuk-radios-fieldset>
            </govuk-radios>

            <govuk-button type="submit">Continue</govuk-button>
        </form>
    </div>
</div>
